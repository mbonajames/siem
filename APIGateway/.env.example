# Copy this file to .env and fill in the real values.
# NEVER commit .env to git.

# ── Wazuh Indexer (OpenSearch) ────────────────────────────────────────────────
WAZUH_INDEXER_URL=https://<wazuh-indexer-ip>:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=<password>

# ── Wazuh Server API (port 55000) ─────────────────────────────────────────────
WAZUH_API_URL=https://<wazuh-manager-ip>:55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASS=<password>
WAZUH_API_VERIFY_CERT=false

# ── Sophos Central ────────────────────────────────────────────────────────────
SOPHOS_CLIENT_ID=<client-id>
SOPHOS_CLIENT_SECRET=<client-secret>
SOPHOS_TENANT_ID=<tenant-id>
SOPHOS_BASE_URL=https://api.central.sophos.com
SOPHOS_TOKEN_URL=https://id.sophos.com/api/v2/oauth2/token

# ── Nessus ────────────────────────────────────────────────────────────────────
NESSUS_URL=https://localhost:8834
NESSUS_ACCESS_KEY=<access-key>
NESSUS_SECRET_KEY=<secret-key>

# ── JIRA ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://<your-org>.atlassian.net
JIRA_EMAIL=<jira-user-email>
JIRA_API_TOKEN=<api-token>
JIRA_PROJECT_KEY=<project-key>

# ── Azure SSO (user authentication) ──────────────────────────────────────────
AZURE_TENANT_ID=<tenant-id>
AZURE_CLIENT_ID=<client-id>
AZURE_API_AUDIENCE=api://<client-id>

# ── Microsoft Defender (separate service principal) ───────────────────────────
# Required Graph permissions (grant admin consent):
#   SecurityAlert.Read.All  SecurityIncident.Read.All  ThreatHunting.Read.All
DEFENDER_CLIENT_ID=<client-id>
DEFENDER_CLIENT_SECRET=<client-secret>

# ── VirusTotal ────────────────────────────────────────────────────────────────
VT_API_KEY=<api-key>

# ── Optional overrides ────────────────────────────────────────────────────────
# DEFENDER_POLL_SECS=300
# DEFENDER_LOOKBACK_HOURS=24
# JIRA_AUTOPOLL_SECS=300
# JIRA_AUTOPOLL_HOURS=24
